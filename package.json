{
  "name": "zeromall-monorepo",
  "version": "1.0.0",
  "description": "ZeroMall - Enterprise E-Commerce Platform (Shopee Clone)",
  "private": true,
  "workspaces": [
    "frontend",
    "services/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:auth": "npm run start:dev -w services/auth-service",
    "dev:product": "npm run start:dev -w services/product-service",
    "dev:order": "npm run start:dev -w services/order-service",
    "dev:payment": "npm run start:dev -w services/payment-service",
    "dev:notification": "npm run start:dev -w services/notification-service",
    "dev:analytics": "npm run start:dev -w services/analytics-service",
    "dev:all": "concurrently \"npm run dev:frontend\" \"npm run dev:auth\" \"npm run dev:product\" \"npm run dev:order\" \"npm run dev:payment\" \"npm run dev:notification\" \"npm run dev:analytics\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
